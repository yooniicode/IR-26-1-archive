      <link name="l"><visual name="v"><geometry><box><size>1.0 0.3 0.002</size></box></geometry>
      <material><ambient>0.9 0.8 0.0 1</ambient><diffuse>1.0 0.9 0.1 1</diffuse></material></visual></link></model>
    <model name="num_a5"><static>true</static><pose>1.4 4.2 0.002 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>1.0 0.3 0.002</size></box></geometry>
